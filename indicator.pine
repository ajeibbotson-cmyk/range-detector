//@version=6
indicator("Range Detector", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

htfInput    = input.timeframe("60", "Analysis Timeframe", tooltip="Timeframe for structural analysis. Must be >= chart timeframe.")
minPivotPct = input.float(0.20, "Min HH/LL Threshold %", minval=0.0, step=0.01, tooltip="Fractal must exceed prior by this % to qualify as HH/LL. Below threshold → classified as LH/HL instead.")
showRefs    = input.bool(true, "Show ref markers")
maxLB       = input.int(2000, "Max lookback bars", minval=50)

cBullBgActive  = color.new(color.green,  80)
cBearBgActive  = color.new(color.red,    80)
cHistBg        = color.new(color.gray,   95)
cBullEdge      = color.new(color.green,  20)
cBearEdge      = color.new(color.red,    20)
cHistEdge      = color.new(color.gray,   80)
cMid           = color.new(color.orange, 20)
cHistMid       = color.new(color.gray,   80)

// ── HTF ALGORITHM ──
calcRanges(float minPct) =>
    // Bill Williams 5-bar fractal
    fh = high[4] < high[2] and high[3] <= high[2] and high[2] >= high[1] and high[2] > high[0]
    fl = low[4] > low[2] and low[3] >= low[2] and low[2] <= low[1] and low[2] < low[0]

    var float lastFH_p = na
    var float lastFL_p = na
    var float current_HH_p = na
    var int   current_HH_t = na
    var float current_LL_p = na
    var int   current_LL_t = na
    var float candidate_HL_p = na
    var int   candidate_HL_t = na
    var float candidate_LH_p = na
    var int   candidate_LH_t = na
    var float refH_p = na
    var int   refH_t = na
    var float refL_p = na
    var int   refL_t = na
    var float structural_HH_p = na
    var int   structural_HH_t = na
    var float structural_LL_p = na
    var int   structural_LL_t = na
    var int   bias   = 0
    var float rHi    = na
    var float rLo    = na
    var int   rStartT = na
    var int   breakT  = na

    if fh
        threshH = nz(lastFH_p) * minPct / 100
        isHH = not na(lastFH_p) and high[2] > lastFH_p + threshH
        isLH = not na(lastFH_p) and not isHH
        if isHH and bias != -1
            current_HH_p := high[2]
            current_HH_t := time[2]
            candidate_HL_p := na
            candidate_HL_t := na
        if isLH and bias != 1
            candidate_LH_p := high[2]
            candidate_LH_t := time[2]
        lastFH_p := high[2]

    if fl
        threshL = nz(lastFL_p) * minPct / 100
        isLL = not na(lastFL_p) and low[2] < lastFL_p - threshL
        isHL = not na(lastFL_p) and not isLL
        if isLL and bias != 1
            current_LL_p := low[2]
            current_LL_t := time[2]
            candidate_LH_p := na
            candidate_LH_t := na
        if isHL and bias != -1
            candidate_HL_p := low[2]
            candidate_HL_t := time[2]
        lastFL_p := low[2]

    newBreak = false

    // HH break — continuation in bull (or initial bias from neutral)
    if (bias == 1 or bias == 0) and not na(current_HH_p) and high >= current_HH_p and not na(candidate_HL_p)
        bias := 1
        refL_p := candidate_HL_p
        refL_t := candidate_HL_t
        structural_HH_p := current_HH_p
        structural_HH_t := current_HH_t
        rHi := current_HH_p
        rLo := candidate_HL_p
        rStartT := current_HH_t
        newBreak := true
        breakT := time
        current_HH_p := na
        current_HH_t := na
        candidate_HL_p := na
        candidate_HL_t := na
        refH_p := na
        refH_t := na
        structural_LL_p := na
        structural_LL_t := na

    // LL break — continuation in bear (or initial)
    if not newBreak and (bias == -1 or bias == 0) and not na(current_LL_p) and low <= current_LL_p and not na(candidate_LH_p)
        bias := -1
        refH_p := candidate_LH_p
        refH_t := candidate_LH_t
        structural_LL_p := current_LL_p
        structural_LL_t := current_LL_t
        rHi := candidate_LH_p
        rLo := current_LL_p
        rStartT := current_LL_t
        newBreak := true
        breakT := time
        current_LL_p := na
        current_LL_t := na
        candidate_LH_p := na
        candidate_LH_t := na
        refL_p := na
        refL_t := na
        structural_HH_p := na
        structural_HH_t := na

    // HL break — flip from bull to bear (trend fails)
    if not newBreak and bias == 1 and not na(refL_p) and close <= refL_p
        bias := -1
        rLo := refL_p
        rHi := na(lastFH_p) ? high : lastFH_p
        rStartT := refL_t
        newBreak := true
        breakT := time
        refH_p := math.max(rHi, high)
        refH_t := time
        refL_p := na
        refL_t := na
        structural_HH_p := na
        structural_HH_t := na
        current_HH_p := na
        current_HH_t := na
        candidate_HL_p := na
        candidate_HL_t := na

    // LH break — flip from bear to bull
    if not newBreak and bias == -1 and not na(refH_p) and close >= refH_p
        bias := 1
        rHi := refH_p
        rLo := na(lastFL_p) ? low : lastFL_p
        rStartT := refH_t
        newBreak := true
        breakT := time
        refL_p := math.min(rLo, low)
        refL_t := time
        refH_p := na
        refH_t := na
        structural_LL_p := na
        structural_LL_t := na
        current_LL_p := na
        current_LL_t := na
        candidate_LH_p := na
        candidate_LH_t := na

    mid = na(rHi) or na(rLo) ? na : (rHi + rLo) / 2.0

    [newBreak, bias, rHi, rLo, mid, rStartT, refH_p, refL_p, breakT]

// ── REQUEST HTF DATA ──
[htfBreak, htfBias, htfHi, htfLo, htfMid, htfStartTime, htfRefH, htfRefL, htfBreakTime] = request.security(syminfo.tickerid, htfInput, calcRanges(minPivotPct), barmerge.gaps_off, barmerge.lookahead_on)

// ── BREAK DEDUPLICATION ──
// request.security forward-fills on every LTF bar; only fire drawing logic once per HTF break
var int lastProcessedBreakTime = 0
isNewBreak = htfBreak and htfBreakTime != lastProcessedBreakTime
if isNewBreak
    lastProcessedBreakTime := htfBreakTime

// ── DRAWINGS (xloc.bar_time so HTF ranges persist on LTF charts) ──
var box   rangeBox  = na
var line  midLine   = na
var label biasLabel = na

if isNewBreak
    if not na(rangeBox)
        box.set_bgcolor(rangeBox, cHistBg)
        box.set_border_color(rangeBox, cHistEdge)
        box.set_border_width(rangeBox, 1)
    if not na(midLine)
        line.set_color(midLine, cHistMid)
    bg   = htfBias == 1 ? cBullBgActive : cBearBgActive
    edge = htfBias == 1 ? cBullEdge     : cBearEdge
    rangeBox  := box.new(htfStartTime, htfHi, htfBreakTime, htfLo, border_color=edge, bgcolor=bg, border_width=2, xloc=xloc.bar_time)
    midLine   := line.new(htfStartTime, htfMid, htfBreakTime, htfMid, color=cMid, style=line.style_dashed, width=2, xloc=xloc.bar_time)
    txt    = htfBias == 1 ? "BUL" : "BER"
    txtCol = htfBias == 1 ? color.green  : color.red
    lblY   = htfBias == 1 ? htfLo : htfHi
    lblSty = htfBias == 1 ? label.style_label_up : label.style_label_down
    biasLabel := label.new(htfBreakTime, lblY, txt, color=txtCol, textcolor=color.white, style=lblSty, size=size.normal, xloc=xloc.bar_time)

// ── FRACTAL MARKERS (only when chart TF >= analysis TF) ──
bool isChartTF = timeframe.in_seconds() >= timeframe.in_seconds(htfInput)
fhChart = high[4] < high[2] and high[3] <= high[2] and high[2] >= high[1] and high[2] > high[0]
flChart = low[4] > low[2] and low[3] >= low[2] and low[2] <= low[1] and low[2] < low[0]
plotshape(isChartTF and showRefs and fhChart ? high[2] : na, title="Fractal H", style=shape.triangledown, location=location.absolute, color=color.new(color.red, 40), size=size.tiny, offset=-2, display=display.all - display.price_scale)
plotshape(isChartTF and showRefs and flChart ? low[2] : na, title="Fractal L", style=shape.triangleup, location=location.absolute, color=color.new(color.green, 40), size=size.tiny, offset=-2, display=display.all - display.price_scale)

// ── INFO TABLE ──
var table tbl = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    tfWarning = timeframe.in_seconds() > timeframe.in_seconds(htfInput)
    biasStr = htfBias == 1 ? "BULLISH" : htfBias == -1 ? "BEARISH" : "NEUTRAL"
    biasCol = htfBias == 1 ? color.green : htfBias == -1 ? color.red : color.gray
    table.cell(tbl, 0, 0, "Bias", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 0, biasStr, text_color=tfWarning ? color.orange : biasCol, text_size=size.small)
    table.cell(tbl, 0, 1, "Range High", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(htfHi, format.mintick), text_color=color.white, text_size=size.small)
    table.cell(tbl, 0, 2, "Range Low", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(htfLo, format.mintick), text_color=color.white, text_size=size.small)
    table.cell(tbl, 0, 3, "50%", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(htfMid, format.mintick), text_color=color.orange, text_size=size.small)
    table.cell(tbl, 0, 4, "LH / HL", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 4, str.tostring(htfRefH, format.mintick) + " / " + str.tostring(htfRefL, format.mintick), text_color=color.gray, text_size=size.small)
    table.cell(tbl, 0, 5, "TF", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 5, htfInput + (tfWarning ? " !" : ""), text_color=tfWarning ? color.orange : color.gray, text_size=size.small)
